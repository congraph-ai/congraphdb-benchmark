{
  "name": "congraphdb-benchmark-ui",
  "version": "1.0.0",
  "description": "Interactive UI for CongraphDB benchmark results",
  "scripts": {
    "generate-results": "node scripts/generate-results.js",
    "generate-charts": "node scripts/generate-charts.js",
