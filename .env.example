# ===========================================
# CongraphDB Benchmark - Environment Variables
# ===========================================
# Copy this file to .env and update with your credentials

# -------------------------------------------------
# Neo4j Configuration (Optional)
# -------------------------------------------------
# Only needed if you want to benchmark against Neo4j
# To skip Neo4j, run: node dist/cli.js run --engines congraph,graphology

# Neo4j connection URI
NEO4J_URI=bolt://localhost:7688

# Neo4j username
NEO4J_USER=neo4j

# Neo4j password
# For Docker: Use the password set with NEO4J_AUTH
# For Desktop: Use your configured password
NEO4J_PASSWORD=neo4j

# Optional: Custom database name (default: neo4j)
# NEO4J_DATABASE=neo4j

# -------------------------------------------------
# Quick Start with Neo4j Docker
# -------------------------------------------------
# docker run -d --name neo4j \\
#   -p 7687:7687 -p 7474:7474 \\
#   -e NEO4J_AUTH=neo4j/benchmark_password \\
#   neo4j:5.26-community
#
# Then set: NEO4J_PASSWORD=benchmark_password
